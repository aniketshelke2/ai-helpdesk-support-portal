{
  "name": "ai-helpdesk-support-portal",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2.8.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "watch-tickets": "cds watch --open helpdesk.ticket.tickets/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/tickets"
  ],





  "cds": {
  "requires": {
    "db": {
      "kind": "sqlite"
    },
    "auth": {
      "kind": "mocked",
      "users": {
        "employee1": {
          "password": "pass",
          "roles": ["Employee"]
        },
        "agent1": {
          "password": "pass",
          "roles": ["SupportAgent"]
        },
        "manager1": {
          "password": "pass",
          "roles": ["Manager"]
        },
        "admin": {
          "password": "pass",
          "roles": ["Admin"]
        }
      }
    }
  },
  "[production]": {
    "requires": {
      "db": {
        "kind": "hana"
      },
      "auth": {
        "kind": "xsuaa"
      }
    }
  }
}

}
